# Backend API base URL (core service)
VITE_API_BASE_URL=http://localhost:2000/api

# Backend API base URL (app service)
VITE_API_APP_BASE_URL=http://localhost:2001/api

# Default route after login
VITE_BASE_HOME_PATH=/home

# App title
VITE_GLOB_APP_TITLE=My App

# App logo URL (leave empty to use local logo)
VITE_GLOB_APP_LOGO_URL=

# Zustand store namespace prefix (prevents key conflicts between multiple projects)
VITE_APP_NAMESPACE=my-app

# Auth provider: supabase (default)
VITE_AUTH_PROVIDER=supabase

# Supabase (required when VITE_AUTH_PROVIDER=supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
